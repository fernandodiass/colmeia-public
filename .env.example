# .env.example
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o .env no Git.

# ── Site ─────────────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://colmeiapublic.com.br

# ── Newsletter (escolha um provider) ────────────────────────────────────────
# Resend (recomendado)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# MailerLite (alternativa)
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=

# ConvertKit (alternativa)
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

# ── Analytics ────────────────────────────────────────────────────────────────
# Cloudflare Web Analytics (não precisa de chave, só ative no dashboard CF)
# Plausible (self-hosted ou cloud)
# PUBLIC_PLAUSIBLE_DOMAIN=colmeiapublic.com.br

# ── Cloudflare ───────────────────────────────────────────────────────────────
# Preenchidos automaticamente pelo Cloudflare Pages em produção
# CF_PAGES_URL=
# CF_PAGES_BRANCH=
# CF_PAGES_COMMIT_SHA=
