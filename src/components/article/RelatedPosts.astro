---
// src/components/article/RelatedPosts.astro
// Para ativar, descomente o bloco getCollection abaixo e remova os mockPosts
import type { Category } from '../content/config';

interface Props {
  category: Category;
  currentSlug: string;
  limit?: number;
}

const { category, currentSlug, limit = 3 } = Astro.props;

// ── Ativar quando tiver artigos publicados ────────────────────────────────────
// import { getCollection } from 'astro:content';
// const all = await getCollection(category, ({ data }) => !data.draft);
// const related = all
//   .filter(p => p.slug !== currentSlug)
//   .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
//   .slice(0, limit);
// ─────────────────────────────────────────────────────────────────────────────

// Placeholder visual (remove quando ativar getCollection)
const mockPosts = Array.from({ length: limit }, (_, i) => ({
  slug: `exemplo-${i + 1}`,
  data: {
    title: `Artigo relacionado ${i + 1} sobre ${category}`,
    description: 'Descrição breve do artigo para o card de relacionados.',
    publishedAt: new Date(),
    readingTime: 5 + i,
  },
}));

const related = mockPosts;
---

{related.length > 0 && (
  <section aria-label="Artigos relacionados">
    <h3 class="text-base font-bold text-zinc-900 dark:text-zinc-100 mb-4">Continue lendo</h3>
    <div class="grid sm:grid-cols-3 gap-4">
      {related.map(post => (
        <a
          href={`/${category}/${post.slug}`}
          class="group flex flex-col p-4 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 hover:border-yellow-400 dark:hover:border-yellow-500 transition-colors"
        >
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-yellow-600 dark:group-hover:text-yellow-400 transition-colors leading-snug mb-2">
            {post.data.title}
          </p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 line-clamp-2 mb-auto">
            {post.data.description}
          </p>
          {post.data.readingTime && (
            <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-3">
              {post.data.readingTime} min
            </p>
          )}
        </a>
      ))}
    </div>
  </section>
)}
