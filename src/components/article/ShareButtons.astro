---
// src/components/article/ShareButtons.astro
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encoded = {
  url: encodeURIComponent(url),
  title: encodeURIComponent(title),
};
---
<div class="flex flex-wrap items-center gap-3">
  <span class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">Compartilhar</span>

  <!-- Web Share API (mobile) -->
  <button
    id="native-share"
    class="hidden items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
    aria-label="Compartilhar via sistema"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
    Compartilhar
  </button>

  <!-- Twitter / X -->
  <a
    href={`https://twitter.com/intent/tweet?text=${encoded.title}&url=${encoded.url}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
    aria-label="Compartilhar no Twitter"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    X
  </a>

  <!-- LinkedIn -->
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encoded.url}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
    aria-label="Compartilhar no LinkedIn"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    LinkedIn
  </a>

  <!-- Copiar link -->
  <button
    id="copy-link"
    data-url={url}
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors"
    aria-label="Copiar link do artigo"
  >
    <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
    <span id="copy-label">Copiar link</span>
  </button>
</div>

<script>
  // Web Share API
  const nativeBtn = document.getElementById('native-share');
  if (nativeBtn && navigator.share) {
    nativeBtn.classList.remove('hidden');
    nativeBtn.classList.add('flex');
    nativeBtn.addEventListener('click', async () => {
      await navigator.share({
        title: document.title,
        url: window.location.href,
      }).catch(() => {});
    });
  }

  // Copiar link
  const copyBtn  = document.getElementById('copy-link');
  const copyLabel = document.getElementById('copy-label');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url') ?? window.location.href;
    await navigator.clipboard.writeText(url);
    if (copyLabel) {
      copyLabel.textContent = 'Copiado!';
      setTimeout(() => { copyLabel.textContent = 'Copiar link'; }, 2000);
    }
  });
</script>
