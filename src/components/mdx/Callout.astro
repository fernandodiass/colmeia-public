---
// src/components/mdx/Callout.astro
// Uso no MDX:
//   <Callout type="tip">Dica importante aqui</Callout>
//   <Callout type="warning" title="Atenção">Mensagem de aviso</Callout>

interface Props {
  type?: 'info' | 'tip' | 'warning' | 'danger' | 'note';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config: Record<string, { icon: string; classes: string; defaultTitle: string }> = {
  info: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>`,
    classes: 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800 text-blue-900 dark:text-blue-100 [&_.callout-icon]:text-blue-500',
    defaultTitle: 'Informação',
  },
  tip: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6M10 22h4"/></svg>`,
    classes: 'bg-yellow-50 dark:bg-yellow-900/20 border-yellow-200 dark:border-yellow-800 text-yellow-900 dark:text-yellow-100 [&_.callout-icon]:text-yellow-500',
    defaultTitle: 'Dica',
  },
  warning: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4M12 17h.01"/></svg>`,
    classes: 'bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800 text-amber-900 dark:text-amber-100 [&_.callout-icon]:text-amber-500',
    defaultTitle: 'Atenção',
  },
  danger: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>`,
    classes: 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800 text-red-900 dark:text-red-100 [&_.callout-icon]:text-red-500',
    defaultTitle: 'Cuidado',
  },
  note: {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    classes: 'bg-zinc-50 dark:bg-zinc-900 border-zinc-200 dark:border-zinc-700 text-zinc-800 dark:text-zinc-200 [&_.callout-icon]:text-zinc-500',
    defaultTitle: 'Nota',
  },
};

const { icon, classes, defaultTitle } = config[type] ?? config.info;
const label = title ?? defaultTitle;
---

<aside
  class:list={['callout not-prose my-6 rounded-xl border p-4 text-sm leading-relaxed', classes]}
  role="note"
  aria-label={label}
>
  <div class="flex items-start gap-3">
    <span class="callout-icon flex-shrink-0 mt-0.5" aria-hidden="true" set:html={icon} />
    <div class="min-w-0">
      <p class="font-semibold text-[13px] uppercase tracking-wide mb-1 opacity-70">{label}</p>
      <div class="[&>p]:mb-0 [&>p]:leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</aside>
