---
// src/components/mdx/PromptCopy.astro
// Uso no MDX:
//   <PromptCopy label="Prompt para rebranding">
//     Você é um especialista em branding...
//   </PromptCopy>

interface Props {
  label?: string;
  model?: string; // ex: "Claude", "ChatGPT", "Midjourney"
}

const { label = 'Prompt', model } = Astro.props;
const id = `prompt-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class="not-prose my-6 rounded-xl border border-zinc-200 dark:border-zinc-700 overflow-hidden bg-zinc-950"
  aria-label={`${label}${model ? ` para ${model}` : ''}`}
>
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-2.5 border-b border-zinc-800 bg-zinc-900">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-yellow-400" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
      <span class="text-xs font-semibold text-zinc-300">{label}</span>
      {model && (
        <span class="text-[10px] px-2 py-0.5 rounded-full bg-yellow-400/15 text-yellow-400 font-medium">
          {model}
        </span>
      )}
    </div>

    <button
      id={`copy-btn-${id}`}
      data-target={id}
      class="flex items-center gap-1.5 text-xs text-zinc-400 hover:text-zinc-200 transition-colors px-2 py-1 rounded-md hover:bg-zinc-800"
      aria-label="Copiar prompt"
    >
      <svg id={`copy-icon-${id}`} xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <span id={`copy-label-${id}`}>Copiar</span>
    </button>
  </div>

  <!-- Conteúdo do prompt -->
  <pre
    id={id}
    class="px-4 py-4 text-sm text-zinc-300 leading-relaxed whitespace-pre-wrap break-words m-0 font-mono overflow-x-auto scrollbar-hide"
  ><slot /></pre>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-target]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target')!;
      const pre = document.getElementById(targetId);
      if (!pre) return;

      const text = pre.innerText.trim();
      await navigator.clipboard.writeText(text);

      const label = document.getElementById(`copy-label-${targetId}`);
      const icon  = document.getElementById(`copy-icon-${targetId}`);

      if (label) label.textContent = 'Copiado!';
      if (icon)  icon.innerHTML = `<path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`;

      setTimeout(() => {
        if (label) label.textContent = 'Copiar';
        if (icon)  icon.innerHTML = `<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>`;
      }, 2000);
    });
  });
</script>
