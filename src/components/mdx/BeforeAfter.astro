---
// src/components/mdx/BeforeAfter.astro
// Uso no MDX:
//   <BeforeAfter
//     before="/images/design-antes.jpg"
//     after="/images/design-depois.jpg"
//     beforeLabel="Antes"
//     afterLabel="Depois"
//     alt="Redesign do dashboard"
//   />

interface Props {
  before: string;
  after: string;
  beforeLabel?: string;
  afterLabel?: string;
  alt?: string;
  height?: number; // px — padrão 400
}

const {
  before,
  after,
  beforeLabel = 'Antes',
  afterLabel  = 'Depois',
  alt         = 'Comparação antes e depois',
  height      = 400,
} = Astro.props;

const id = `ba-${Math.random().toString(36).slice(2, 8)}`;
---

<figure
  class="not-prose my-8 rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 select-none"
  aria-label={alt}
  style={`height: ${height}px`}
>
  <div id={id} class="relative w-full h-full cursor-ew-resize overflow-hidden" role="img" aria-label={alt}>
    <!-- Imagem DEPOIS (base) -->
    <img
      src={after}
      alt={`${alt} — ${afterLabel}`}
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      draggable="false"
      loading="lazy"
    />

    <!-- Imagem ANTES (recortada via clip) -->
    <div
      id={`${id}-clip`}
      class="absolute inset-0 overflow-hidden"
      style="width: 50%"
    >
      <img
        src={before}
        alt={`${alt} — ${beforeLabel}`}
        class="absolute inset-0 w-full h-full object-cover pointer-events-none"
        style={`width: ${id}-width`}
        draggable="false"
        loading="lazy"
      />
    </div>

    <!-- Handle central -->
    <div
      id={`${id}-handle`}
      class="absolute top-0 bottom-0 flex flex-col items-center justify-center z-10"
      style="left: 50%; transform: translateX(-50%)"
    >
      <!-- Linha vertical -->
      <div class="w-0.5 h-full bg-white/90 shadow-[0_0_8px_rgba(0,0,0,0.4)]"></div>
      <!-- Botão central -->
      <div class="absolute w-10 h-10 rounded-full bg-white shadow-lg flex items-center justify-center gap-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 18-6-6 6-6"/><path d="m15 6 6 6-6 6"/>
        </svg>
      </div>
    </div>

    <!-- Labels -->
    <span class="absolute top-3 left-3 z-20 text-xs font-bold text-white bg-black/50 px-2.5 py-1 rounded-full backdrop-blur-sm">
      {beforeLabel}
    </span>
    <span class="absolute top-3 right-3 z-20 text-xs font-bold text-white bg-black/50 px-2.5 py-1 rounded-full backdrop-blur-sm">
      {afterLabel}
    </span>
  </div>

  {alt && <figcaption class="sr-only">{alt}</figcaption>}
</figure>

<script define:vars={{ id }}>
  const container = document.getElementById(id);
  const clip      = document.getElementById(`${id}-clip`);
  const handle    = document.getElementById(`${id}-handle`);
  if (!container || !clip || !handle) return;

  let dragging = false;

  function setPosition(clientX) {
    const rect  = container.getBoundingClientRect();
    const pct   = Math.min(100, Math.max(0, ((clientX - rect.left) / rect.width) * 100));
    clip.style.width   = `${pct}%`;
    handle.style.left  = `${pct}%`;
  }

  container.addEventListener('mousedown',  () => { dragging = true; });
  container.addEventListener('touchstart', () => { dragging = true; }, { passive: true });

  window.addEventListener('mousemove',  e => { if (dragging) setPosition(e.clientX); });
  window.addEventListener('touchmove',  e => { if (dragging) setPosition(e.touches[0].clientX); }, { passive: true });

  window.addEventListener('mouseup',   () => { dragging = false; });
  window.addEventListener('touchend',  () => { dragging = false; });
</script>
