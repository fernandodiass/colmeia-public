---
// src/components/global/ThemeToggle.astro
// Sem props — lê e escreve diretamente no <html> e localStorage
---

<button
  id="theme-toggle"
  type="button"
  class="relative flex items-center justify-center w-9 h-9 rounded-lg text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
  aria-label="Alternar tema"
  title="Alternar modo escuro / claro"
>
  <!-- Ícone Sol (visível no modo escuro) -->
  <svg
    id="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden dark:block transition-transform duration-300"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>

  <!-- Ícone Lua (visível no modo claro) -->
  <svg
    id="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="block dark:hidden transition-transform duration-300"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  const html = document.documentElement;

  function getTheme(): 'dark' | 'light' {
    return html.classList.contains('dark') ? 'dark' : 'light';
  }

  function applyTheme(theme: 'dark' | 'light') {
    if (theme === 'dark') {
      html.classList.add('dark');
    } else {
      html.classList.remove('dark');
    }
    localStorage.setItem('theme', theme);
    btn?.setAttribute('aria-label', theme === 'dark' ? 'Ativar modo claro' : 'Ativar modo escuro');
  }

  btn?.addEventListener('click', () => {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });

  // Sincroniza se outra aba mudar o tema
  window.addEventListener('storage', (e) => {
    if (e.key === 'theme' && (e.newValue === 'dark' || e.newValue === 'light')) {
      applyTheme(e.newValue);
    }
  });

  // Sincroniza se o sistema mudar (só se não houver preferência salva)
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      applyTheme(e.matches ? 'dark' : 'light');
    }
  });
</script>
