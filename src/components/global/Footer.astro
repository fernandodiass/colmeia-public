---
// src/components/global/Footer.astro
const year = new Date().getFullYear();

const categories = [
  { href: '/design',    label: 'Design' },
  { href: '/dev',       label: 'Desenvolvimento' },
  { href: '/marketing', label: 'Marketing' },
  { href: '/ia',        label: 'Inteligência Artificial' },
];

const links = {
  sobre: [
    { href: '/sobre',    label: 'Sobre o projeto' },
    { href: '/contato',  label: 'Contato' },
    { href: '/anuncie',  label: 'Anuncie aqui' },
  ],
  legal: [
    { href: '/privacidade',  label: 'Privacidade' },
    { href: '/termos',       label: 'Termos de uso' },
  ],
};
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Grade principal -->
    <div class="py-12 grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4 group" aria-label="Colmeia Public — início">
          <div class="w-8 h-8 rounded-lg bg-yellow-400 flex items-center justify-center text-black font-black text-sm leading-none">C</div>
          <span class="font-bold text-[15px] tracking-tight text-zinc-900 dark:text-white">Colmeia<span class="text-yellow-500">.</span></span>
        </a>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-[220px]">
          Soluções técnicas e visuais para quem cria na internet.
        </p>
      </div>

      <!-- Categorias -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Conteúdo</p>
        <ul class="space-y-2.5">
          {categories.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Sobre -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Sobre</p>
        <ul class="space-y-2.5">
          {links.sobre.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter mini -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500 mb-4">Newsletter</p>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-3">
          Novidades direto na sua caixa toda semana.
        </p>
        <form
          id="footer-newsletter-form"
          class="flex flex-col gap-2"
          novalidate
        >
          <input
            type="email"
            name="email"
            placeholder="seu@email.com"
            required
            autocomplete="email"
            class="w-full px-3 py-2.5 rounded-lg text-sm bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-transparent transition"
          />
          <button
            type="submit"
            class="w-full py-2.5 px-4 rounded-lg text-sm font-semibold bg-yellow-400 text-black hover:bg-yellow-300 transition-colors"
          >
            Assinar grátis
          </button>
          <p id="footer-form-msg" class="text-xs text-zinc-400 hidden"></p>
        </form>
      </div>

    </div>

    <!-- Rodapé inferior -->
    <div class="py-6 border-t border-zinc-200 dark:border-zinc-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-400 dark:text-zinc-600">
      <p>© {year} Colmeia Public. Todos os direitos reservados.</p>
      <div class="flex items-center gap-4">
        {links.legal.map(({ href, label }) => (
          <a href={href} class="hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>

<script>
  const form = document.getElementById('footer-newsletter-form') as HTMLFormElement | null;
  const msg  = document.getElementById('footer-form-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    if (!email) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enviando…';

    // TODO: substituir por integração real (Resend, Mailchimp, ConvertKit etc.)
    await new Promise(r => setTimeout(r, 800));

    if (msg) {
      msg.textContent = '✓ Inscrição confirmada! Bem-vindo(a) à Colmeia.';
      msg.classList.remove('hidden', 'text-red-500');
      msg.classList.add('text-green-600', 'dark:text-green-400');
    }
    form.reset();
    btn.disabled = false;
    btn.textContent = 'Assinar grátis';
  });
</script>
