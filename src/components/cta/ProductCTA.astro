---
// src/components/cta/ProductCTA.astro
// CTA de infoproduto (Pack de UI, E-book, Prompts, etc.)
// Alimentado por um mapa de produtos — fácil de escalar.

interface Product {
  id: string;
  name: string;
  tagline: string;
  description: string;
  price: string;      // ex: "R$ 47"
  priceNote?: string; // ex: "pagamento único"
  href: string;       // link da landing page / checkout
  badge?: string;     // ex: "Novo", "Mais vendido"
  emoji: string;
}

// ── Catálogo de produtos (adicione aqui conforme lançar) ─────────────────────
const PRODUCTS: Record<string, Product> = {
  'pack-ui-components': {
    id: 'pack-ui-components',
    name: 'Pack de Componentes UI',
    tagline: 'Componentes Tailwind prontos para produção',
    description: '50+ componentes Astro/React com dark mode, acessibilidade e zero dependências. Copie, cole e ship.',
    price: 'R$ 97',
    priceNote: 'pagamento único • acesso vitalício',
    href: '/produtos/pack-ui-components',
    badge: 'Mais vendido',
    emoji: '🧩',
  },
  'ebook-seo-jamstack': {
    id: 'ebook-seo-jamstack',
    name: 'SEO para Jamstack',
    tagline: 'Guia completo de SEO técnico para sites estáticos',
    description: 'Da estrutura de URLs ao Schema markup. Tudo que você precisa para dominar o Google com Astro ou Next.js.',
    price: 'R$ 47',
    priceNote: 'acesso imediato • PDF + Notion',
    href: '/produtos/ebook-seo-jamstack',
    emoji: '📖',
  },
  'pack-prompts-ia': {
    id: 'pack-prompts-ia',
    name: 'Pack de Prompts IA',
    tagline: '200+ prompts para Design e Marketing',
    description: 'Prompts testados para Midjourney, Claude, ChatGPT e Stable Diffusion organizados por caso de uso.',
    price: 'R$ 37',
    priceNote: 'acesso vitalício + atualizações',
    href: '/produtos/pack-prompts-ia',
    badge: 'Novo',
    emoji: '🤖',
  },
};

interface Props {
  productId: string;
  position: 'inline' | 'bottom';
}

const { productId, position } = Astro.props;
const product = PRODUCTS[productId];
---

{product && (
  <aside
    data-cta="product"
    data-product={productId}
    class:list={[
      'rounded-2xl border overflow-hidden my-8',
      position === 'bottom'
        ? 'bg-zinc-900 dark:bg-zinc-800 border-zinc-700'
        : 'bg-gradient-to-br from-yellow-50 to-white dark:from-zinc-900 dark:to-zinc-900 border-yellow-200 dark:border-yellow-800/40',
    ]}
    aria-label={`Produto: ${product.name}`}
  >
    <div class="p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row sm:items-start gap-5">

        <!-- Emoji / ícone -->
        <div class:list={[
          'w-14 h-14 rounded-2xl flex-shrink-0 flex items-center justify-center text-2xl',
          position === 'bottom'
            ? 'bg-zinc-800 dark:bg-zinc-700'
            : 'bg-yellow-400/20 dark:bg-yellow-400/10',
        ]}>
          {product.emoji}
        </div>

        <!-- Texto -->
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <p class:list={[
              'text-xs font-semibold uppercase tracking-wider',
              position === 'bottom' ? 'text-yellow-400' : 'text-yellow-600 dark:text-yellow-400',
            ]}>
              {product.tagline}
            </p>
            {product.badge && (
              <span class="text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full bg-yellow-400 text-black">
                {product.badge}
              </span>
            )}
          </div>

          <h3 class:list={[
            'text-xl font-black mb-2',
            position === 'bottom' ? 'text-white' : 'text-zinc-900 dark:text-zinc-100',
          ]}>
            {product.name}
          </h3>

          <p class:list={[
            'text-sm leading-relaxed mb-5',
            position === 'bottom' ? 'text-zinc-400' : 'text-zinc-600 dark:text-zinc-400',
          ]}>
            {product.description}
          </p>

          <!-- Preço + CTA -->
          <div class="flex flex-wrap items-center gap-4">
            <div>
              <span class:list={[
                'text-2xl font-black',
                position === 'bottom' ? 'text-white' : 'text-zinc-900 dark:text-zinc-100',
              ]}>
                {product.price}
              </span>
              {product.priceNote && (
                <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5">{product.priceNote}</p>
              )}
            </div>

            <a
              href={product.href}
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold bg-yellow-400 text-black hover:bg-yellow-300 transition-colors"
            >
              Quero esse produto
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </aside>
)}

{!product && (
  <!-- Fallback amigável para product ID inválido -->
  <aside class="my-8 p-5 rounded-xl border border-dashed border-zinc-300 dark:border-zinc-700 text-center text-sm text-zinc-400">
    ⚠️ Produto <code class="font-mono">{productId}</code> não encontrado em <code class="font-mono">ProductCTA.astro</code>. Adicione-o ao catálogo PRODUCTS.
  </aside>
)}
