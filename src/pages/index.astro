---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import NewsletterCTA from '../components/cta/NewsletterCTA.astro';
import { generateWebSiteSchema } from '../lib/schema';
// import { getCollection } from 'astro:content';

// ── Quando houver artigos, substituir os mocks por: ──────────────────────────
// const allPosts = await getCollection('design', ({ data }) => !data.draft)
//   .then(posts => [...posts, ...await getCollection('dev',       ({ data }) => !data.draft)])
//   .then(posts => [...posts, ...await getCollection('marketing', ({ data }) => !data.draft)])
//   .then(posts => [...posts, ...await getCollection('ia',        ({ data }) => !data.draft)])
//   .then(posts => posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()));
// const featured = allPosts.filter(p => p.data.featured).slice(0, 4);
// const recent   = allPosts.slice(0, 8);
// ─────────────────────────────────────────────────────────────────────────────

// Mock para desenvolvimento visual
const categories = [
  { slug: 'design',    label: 'Design',        emoji: '🎨', color: 'from-violet-500 to-purple-600' },
  { slug: 'dev',       label: 'Dev',           emoji: '⚡', color: 'from-blue-500 to-cyan-600' },
  { slug: 'marketing', label: 'Marketing',     emoji: '📈', color: 'from-emerald-500 to-teal-600' },
  { slug: 'ia',        label: 'IA',            emoji: '🤖', color: 'from-amber-500 to-orange-600' },
];

const mockFeatured = [
  { slug: 'guia-tipografia-2025',       category: 'design',    title: 'Guia definitivo de tipografia para interfaces em 2025',           readingTime: 12, featured: true },
  { slug: 'astro-vs-nextjs',            category: 'dev',       title: 'Astro vs Next.js: qual escolher para seu projeto?',                readingTime: 8,  featured: true },
  { slug: 'funil-de-conteudo-b2b',      category: 'marketing', title: 'Como construir um funil de conteúdo que converte de verdade',      readingTime: 10, featured: false },
  { slug: 'prompts-midjourney-v6',      category: 'ia',        title: 'Os melhores prompts para Midjourney V6 por tipo de projeto',       readingTime: 6,  featured: false },
];

const mockRecent = [
  { slug: 'dark-mode-css',         category: 'dev',       title: 'Dark mode perfeito com CSS variables e zero JavaScript',    readingTime: 5 },
  { slug: 'color-theory-ui',       category: 'design',    title: 'Teoria das cores aplicada a interfaces digitais',           readingTime: 9 },
  { slug: 'seo-tecnico-2025',      category: 'marketing', title: 'Checklist completo de SEO técnico para Jamstack',           readingTime: 7 },
  { slug: 'claude-api-automacao',  category: 'ia',        title: 'Automações práticas com a API da Claude',                  readingTime: 8 },
  { slug: 'grid-layout-avancado',  category: 'design',    title: 'CSS Grid avançado: layouts impossíveis que funcionam',      readingTime: 11 },
  { slug: 'cloudflare-workers',    category: 'dev',       title: 'Cloudflare Workers: serverless na borda sem dor',           readingTime: 6 },
];

const categoryColor: Record<string, string> = {
  design: 'bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300',
  dev:    'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300',
  marketing: 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300',
  ia:     'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300',
};

const jsonLd = generateWebSiteSchema();
---

<BaseLayout
  title="Soluções reais de Design, Dev, Marketing e IA"
  description="Colmeia Public é um repositório técnico e visual de soluções acionáveis para quem cria na internet. Tutoriais, ferramentas e recursos práticos toda semana."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head-extra" />

  <Header slot="header" />

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="relative pt-32 pb-20 sm:pt-40 sm:pb-28 overflow-hidden">
    <!-- Fundo decorativo -->
    <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-yellow-400/8 dark:bg-yellow-400/5 rounded-full blur-3xl"></div>
      <div class="absolute top-20 right-0 w-72 h-72 bg-violet-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <!-- Label -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold bg-yellow-400/15 text-yellow-700 dark:text-yellow-400 mb-6 border border-yellow-400/20">
          <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></span>
          Conteúdo técnico toda semana
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight text-zinc-900 dark:text-white mb-6 text-balance">
          Soluções reais para quem
          <span class="text-yellow-500"> cria na internet</span>
        </h1>

        <p class="text-lg sm:text-xl text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8 max-w-xl">
          Design, Dev, Marketing e IA. Tutoriais práticos, componentes prontos e estratégias que funcionam — sem enrolação.
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="/blog" class="btn-primary text-base px-6 py-3">
            Explorar conteúdo
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href="#newsletter" class="btn-outline text-base px-6 py-3">
            Newsletter grátis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CATEGORIAS ────────────────────────────────────────────── -->
  <section class="py-10 border-y border-zinc-100 dark:border-zinc-800/60" aria-label="Categorias">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {categories.map(({ slug, label, emoji, color }) => (
          <a
            href={`/${slug}`}
            class="group flex items-center gap-3 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 hover:border-yellow-400 dark:hover:border-yellow-500 transition-all hover:-translate-y-0.5"
          >
            <div class={`w-9 h-9 rounded-lg bg-gradient-to-br ${color} flex items-center justify-center text-lg flex-shrink-0`}>
              {emoji}
            </div>
            <span class="font-semibold text-sm text-zinc-800 dark:text-zinc-200 group-hover:text-yellow-700 dark:group-hover:text-yellow-400 transition-colors">
              {label}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── DESTAQUE (grid assimétrico) ──────────────────────────── -->
  <section class="py-16 sm:py-20" aria-labelledby="featured-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 id="featured-heading" class="text-2xl font-bold text-zinc-900 dark:text-white">Em destaque</h2>
        <a href="/blog" class="text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-yellow-600 dark:hover:text-yellow-400 transition-colors flex items-center gap-1">
          Ver todos
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <!-- Grid 2+2 -->
      <div class="grid md:grid-cols-2 gap-5">
        {mockFeatured.map((post, i) => (
          <a
            href={`/${post.category}/${post.slug}`}
            class:list={[
              'group article-card',
              i === 0 ? 'md:row-span-2 flex-col justify-between min-h-[280px]' : ''
            ]}
          >
            <!-- Placeholder de imagem -->
            <div class:list={[
              'w-full rounded-lg bg-gradient-to-br mb-4 flex-shrink-0',
              i === 0 ? 'h-48' : 'h-32',
              categories.find(c => c.slug === post.category)?.color ?? 'from-zinc-300 to-zinc-400',
              'opacity-20 dark:opacity-10'
            ]}></div>

            <div class="flex-1 flex flex-col">
              <div class="flex items-center gap-2 mb-3">
                <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-md', categoryColor[post.category]]}>
                  {post.category}
                </span>
                <span class="text-xs text-zinc-400">{post.readingTime} min</span>
              </div>
              <h3 class:list={[
                'font-bold leading-snug text-zinc-900 dark:text-zinc-100 group-hover:text-yellow-600 dark:group-hover:text-yellow-400 transition-colors text-balance',
                i === 0 ? 'text-xl' : 'text-base'
              ]}>
                {post.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── RECENTES ──────────────────────────────────────────────── -->
  <section class="py-8 pb-20" aria-labelledby="recent-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 id="recent-heading" class="text-2xl font-bold text-zinc-900 dark:text-white">Publicados recentemente</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {mockRecent.map((post) => (
          <a href={`/${post.category}/${post.slug}`} class="group article-card">
            <div class="flex items-center gap-2 mb-3">
              <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-md', categoryColor[post.category]]}>
                {post.category}
              </span>
              <span class="text-xs text-zinc-400">{post.readingTime} min</span>
            </div>
            <h3 class="font-semibold text-base leading-snug text-zinc-900 dark:text-zinc-100 group-hover:text-yellow-600 dark:group-hover:text-yellow-400 transition-colors text-balance">
              {post.title}
            </h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── NEWSLETTER CTA FULL ──────────────────────────────────── -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <NewsletterCTA
      position="bottom"
      headline="Receba o melhor da Colmeia toda semana"
      subline="Design, Dev, Marketing e IA em uma newsletter enxuta. Sem spam, só conteúdo que vale o seu tempo."
    />
  </section>

  <Footer slot="footer" />
</BaseLayout>
